datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id
  email          String?         @unique
  passwordHash   String?
  displayName    String?
  avatar         String?
  bio            String?
  riotId         String?         @unique
  rank           String?
  valoScore      Int             @default(100)
  isSuspicious   Boolean         @default(false)
  isAdmin        Boolean         @default(false)
  squadsJoined   LobbyMember[]
  squadsLed      Lobby[]
  reputationLogs ReputationLog[]
  ratingsGiven   RatingRecord[]  @relation("RaterRecords")
  ratingsReceived RatingRecord[] @relation("TargetRecords")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Lobby {
  id               String        @id @default(uuid())
  captainId        String
  captain          User          @relation(fields: [captainId], references: [id])
  gameMode         String
  minRank          String?
  maxRank          String?
  description      String?
  status           String        @default("OPEN")
  voiceChannelId   String?
  discordChannelId String?
  discordMessageId String?
  discordGuildId   String?
  members          LobbyMember[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model LobbyMember {
  lobbyId  String
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inVoice  Boolean  @default(false)
  isMuted  Boolean  @default(false)
  joinedAt DateTime @default(now())

  @@id([lobbyId, userId])
}

model ServerConfig {
  guildId         String  @id
  lobbyChannelId  String?
  voiceCategoryId String?
  autoVoice       Boolean @default(true)
  minValoScore    Int     @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReputationLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldScore  Int
  newScore  Int
  reason    String?
  createdAt DateTime @default(now())
}

model RatingRecord {
  id         String   @id @default(uuid())
  raterId    String
  rater      User     @relation("RaterRecords", fields: [raterId], references: [id], onDelete: Cascade)
  targetId   String
  target     User     @relation("TargetRecords", fields: [targetId], references: [id], onDelete: Cascade)
  ratingType String
  suspicious Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([raterId, targetId, ratingType])
  @@index([raterId, targetId])
}
