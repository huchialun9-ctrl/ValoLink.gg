# PostgreSQL database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/valolink?schema=public"

# Discord Developer application credentials
DISCORD_TOKEN="YOUR_DISCORD_BOT_TOKEN"
CLIENT_ID="YOUR_DISCORD_CLIENT_ID"
CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"
REDIRECT_URI="https://your-domain.com/api/auth/callback" # Must match Discord Developer Portal OAuth2 Redirects
GUILD_ID="YOUR_TEST_GUILD_ID" # Optional: for faster guild command sync

# Riot API Key for ranks and match statistics verification
RIOT_API_KEY="RGAPI-XXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
